# Force LF line endings for all text files in this repo.
# Prevents CRLF/LF noise in diffs on Windows machines.

* text=auto eol=lf

# Explicitly LF for source code
*.py    text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.txt   text eol=lf
*.env   text eol=lf
*.ps1   text eol=crlf

# Binary files — never touch line endings
*.png   binary
*.jpg   binary
*.ico   binary
*.pdf   binary
